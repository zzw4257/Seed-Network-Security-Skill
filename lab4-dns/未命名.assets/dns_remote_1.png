<script src="https://cdnjs.cloudflare.com/ajax/libs/color-thief/2.3.2/color-thief.umd.js"></script>
<script>
  window.addEventListener('load', function () {
    const colorThief = new ColorThief();

    document.querySelectorAll('.coursebox').forEach(function (box) {
      const bgDiv = box.querySelector('.courseimage');

      if (!bgDiv) return;

      const bgImage = window.getComputedStyle(bgDiv).backgroundImage;
      const urlMatch = bgImage.match(/url\(["']?(.*?)["']?\)/);
      if (!urlMatch) return;

      const imageUrl = urlMatch[1];

      const img = new Image();
      img.crossOrigin = 'anonymous';
      img.src = imageUrl;

      img.onload = function () {
        try {
          const color = colorThief.getColor(img);
          
          // 设置卡片背景为浅色的半透明
          box.style.backgroundColor = `rgba(${color.join(',')}, 0.25)`;  // 透明度设置为0.15
          
         
        } catch (e) {
          console.warn('提取颜色失败：', e);
        }
      };
    });
  });
</script>
<script>
document.addEventListener("DOMContentLoaded", function() {
    // 遍历所有 block-text-box
    document.querySelectorAll(".block-text-box").forEach(box => {
        const h6Elements = box.querySelectorAll("h6");
        if (h6Elements.length >= 2) {
            const firstText = h6Elements[0].textContent.trim();
            const secondText = h6Elements[1].textContent.trim();
            const match = secondText.match(/\d+/);

            if (firstText === "综合" && match) {
                const number = match[0];
                h6Elements[1].textContent = `${number} 本教科书`;
            } else if (secondText.includes("课程") && match) {
                const number = match[0];
                h6Elements[1].textContent = `${number} 个实验`;
            }
        }
    });
});
</script>
