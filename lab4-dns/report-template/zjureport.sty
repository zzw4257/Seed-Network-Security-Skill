%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% ZJU 实验报告模板（基于 vendor 模板整理）
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ProvidesPackage{zjureport}

%% 页边距
\RequirePackage[left=2.50cm, right=2.50cm, top=2.50cm, bottom=2.50cm]{geometry}

%% 基础宏包
\PassOptionsToPackage{hyphens}{url}
\RequirePackage[unicode=true,colorlinks,urlcolor=blue,linkcolor=blue,bookmarksnumbered=true]{hyperref}
\RequirePackage{latexsym,amssymb,amsmath,amsbsy,amsopn,amstext,amsthm,amsxtra,bm,calc,ifpdf}
\RequirePackage{graphicx}
\RequirePackage{enumerate}
\RequirePackage{fancyhdr}
\RequirePackage{listings}
\RequirePackage{makeidx}
\RequirePackage{xcolor}
\RequirePackage{subfigure}
\RequirePackage{ulem}

%% 中文字体与名称
\IfFileExists{/fonts/STSONG.TTF}{
    \setCJKmainfont[
        Path=/fonts/,
        AutoFakeBold=2.4,
        AutoFakeSlant=.15
    ]{STSONG.TTF}
    \setCJKsansfont[
        Path=/fonts/,
        AutoFakeBold=2.2
    ]{simhei.ttf}
    \setCJKmonofont[
        Path=/fonts/,
        AutoFakeBold=2.2
    ]{simsun.ttc}
    \newCJKfontfamily\zjuheiti[Path=/fonts/,AutoFakeBold=2.2]{simhei.ttf}
    \newCJKfontfamily\zjukaishu[Path=/fonts/,AutoFakeBold=2.2]{STKAITI.TTF}
    \newCJKfontfamily\zjufangsong[Path=/fonts/,AutoFakeBold=2.2]{simfang.ttf}
}{
    % Fallback for environments without /fonts mounted (e.g. local macOS build).
    \setCJKmainfont{Songti SC}
    \setCJKsansfont{PingFang SC}
    \setCJKmonofont{STHeiti}
    \newCJKfontfamily\zjuheiti{PingFang SC}
    \newCJKfontfamily\zjukaishu{Kaiti SC}
    \newCJKfontfamily\zjufangsong{Songti SC}
}
\renewcommand{\abstractname}{\textbf{\large {摘\quad 要}}}
\renewcommand{\contentsname}{目录}
\renewcommand{\figurename}{图}
\renewcommand{\tablename}{表}

%% 固定长度下划线
\makeatletter
\newcommand\dlmu[2][4cm]{\hskip1pt\underline{\hb@xt@ #1{\hss#2\hss}}\hskip3pt}
\makeatother

\newcommand{\munderline}[2][8cm]{%
    \makebox[#1][l]{\uline{#2}}%
}

%% 自动引用中文名
\def\equationautorefname{式}
\def\footnoteautorefname{脚注}
\def\itemautorefname{项}
\def\figureautorefname{图}
\def\tableautorefname{表}
\def\partautorefname{篇}
\def\appendixautorefname{附录}
\def\chapterautorefname{章}
\def\sectionautorefname{节}
\def\subsectionautorefname{小节}
\def\subsubsectionautorefname{子小节}
\def\paragraphautorefname{段落}
\def\subparagraphautorefname{子段落}
\def\FancyVerbLineautorefname{行}
\def\theoremautorefname{定理}

\newtheorem{Theorem}{定理}[section]
\newtheorem{Lemma}[Theorem]{引理}
\newtheorem{Corollary}[Theorem]{推论}
\newtheorem{Proposition}[Theorem]{命题}
\newtheorem{Definition}[Theorem]{定义}
\newtheorem{Example}[Theorem]{例}

%% 参考文献设置
\newcommand{\reference}{
\bibliographystyle{unsrt}
\begin{center}
    \bibliography{reference}
\end{center}
}

%% 盒子样式
\newcommand{\tbox}[1]{
\begin{center}
\setlength{\fboxsep}{8pt}%
\fbox{\begin{minipage}{0.90\linewidth}#1\end{minipage}}
\end{center}
}

